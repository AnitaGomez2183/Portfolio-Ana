---
import LanguageSwitcher from "./LanguageSwitcher.astro";
---

<header class="header">
  <div class="container header__inner">
    <a href="/" class="header__logo" aria-label="Home">Ana Laura Gómez</a>

    <nav class="header__nav" aria-label="Main navigation">
      <a href="#about" class="header__link" data-i18n="nav-about">About</a>
      <a href="#projects" class="header__link" data-i18n="nav-projects">Projects</a>
      <a href="#process" class="header__link" data-i18n="nav-process">Process</a>
      <a href="#contact" class="header__link" data-i18n="nav-contact">Contact</a>
    </nav>

    <div class="header__right">
      <LanguageSwitcher />
      <a href="#contact" class="btn btn--primary header__cta" data-i18n="nav-cta">Let's talk</a>
      <button class="header__hamburger" aria-label="Toggle menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<div class="mobile-nav" aria-hidden="true">
  <a href="#about" class="mobile-nav__link" data-i18n="nav-about">About</a>
  <a href="#projects" class="mobile-nav__link" data-i18n="nav-projects">Projects</a>
  <a href="#process" class="mobile-nav__link" data-i18n="nav-process">Process</a>
  <a href="#contact" class="mobile-nav__link" data-i18n="nav-contact">Contact</a>
  <a href="#contact" class="btn btn--primary" style="align-self:flex-start" data-i18n="nav-cta">Let's talk</a>
</div>
